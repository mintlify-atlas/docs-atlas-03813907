  "keyFeatures": [
    "Multi-wing school support (Regular, Islamiyyah, Tahfeez)",
    "JWT-based authentication with role-based access control (10 roles)",
    "Full academic lifecycle: classes, subjects, timetables, scores, report cards",
    "Qur'an Tahfeez (memorization) progress tracking with Juz and recitation sessions",
    "Admissions pipeline: applications, entrance exams, and alumni registration",
    "Finance management: fee structures, payments, scholarships, and marketplace",
    "Student welfare: health profiles, counselling, discipline, and interventions",
    "Library and transport services management",
    "Communication hub: announcements, notifications, direct messages, Q&A board",
    "Content management: news, events, gallery, magazine, yearbook, testimonials",
    "Soft-delete and audit trail mixins on all sensitive models",
    "Cloudinary integration for media storage"
  ],
  "publicApiSurface": [
    "POST /api/accounts/users/ — create user",
    "GET /api/accounts/users/{id}/ — retrieve user",
    "POST /api/accounts/people/ — create person identity record",
    "GET/POST /api/administration/academic-sessions/ — manage academic sessions",
    "GET/POST /api/administration/terms/ — manage terms",
    "GET/POST /api/administration/wings/ — manage school wings",
    "GET/POST /api/administration/campuses/ — manage campuses",
